# Example Environment Variables for Local Development
# Copy this file to .env and fill in your values

# Django Settings
SECRET_KEY=django-insecure-dev-only-local-testing-do-not-use-in-production
DEBUG=True
ADMIN_REGISTRATION_KEY=dev-admin-key-local-only

# Email Configuration (optional for local testing)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Database Configuration
# For local SQLite (default):
# DATABASE_URL=sqlite:///db.sqlite3

# For local PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/fundi_dev
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=fundi_dev
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# Paystack Payment Configuration
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=DEBUG

# Railway (only if deploying to Railway)
# RAILWAY_PUBLIC_DOMAIN=your-domain.railway.app
